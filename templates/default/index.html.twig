{% extends 'layout.html.twig' %}

{% block title %}Salutations{% endblock %}

{% block body %}

    {% block header %}
        <h1>{{ 'Un titre magnifique'|capitalize }}</h1>
    {% endblock %}

    {% block content %}
        <table>
            <tr>
                <td>Email</td>
                <td>Subject</td>
                <td>Message</td>
            </tr>
            {% for contact in contacts %}
                <tr>
                    <td>
                        {{ contact.email }}
                    <td>
                    <td>
                        {{ contact.subject }}
                    <td>
                    <td>
                        {{ contact.message}}
                    <td></td>
                </tr>
            {% endfor %}
        </table>
    {% endblock %}

{% endblock %}

